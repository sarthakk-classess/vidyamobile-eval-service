# ── Gemini (required) ─────────────────────────────────────────────────────────
# SK-02 embedding (text-embedding-2, 1536-dim) + SK-08 live eval classifier
GEMINI_API_KEY=your-gemini-api-key-here

# SK-08 live eval: classifier (Haiku-class) + frontier (Sonnet-class)
GEMINI_CLASSIFIER_KEY=your-gemini-classifier-key-here
GEMINI_FRONTIER_KEY=your-gemini-frontier-key-here

# ── Supabase (required for live retrieval) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── AI Service (SK-08 live eval) ──────────────────────────────────────────────
# URL of Himanshu's HK-00/05 service exposing POST /v1/turn
AI_SERVICE_URL=http://localhost:8000

# ── Mastery ───────────────────────────────────────────────────────────────────
MASTERY_DESIRED_RETENTION=0.90

# ── Eval Service (this service) ───────────────────────────────────────────────
EVAL_SERVICE_HOST=0.0.0.0
EVAL_SERVICE_PORT=8002
LOG_LEVEL=info
